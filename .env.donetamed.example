# Klinika — DonetaMED on-prem env template
# Copy this file to /srv/sites/klinika-health/.env on the laptop ONLY.
# Never commit a real .env.donetamed — it carries credentials and is
# gitignored.
#
# Generate the secret values once on the laptop:
#     openssl rand -hex 32   # AUTH_SECRET
#     openssl rand -hex 32   # POSTGRES_PASSWORD
#     openssl rand -hex 16   # each SEED_*_PASSWORD
#
# The docker compose command loads this file via
# `--env-file /srv/sites/klinika-health/.env`. See infra/DONETAMED.md
# for the bootstrap procedure.

# ------------------------------------------------------------------
# Runtime
# ------------------------------------------------------------------
NODE_ENV=production
TZ=Europe/Belgrade
APP_VERSION=donetamed
LOG_LEVEL=info

# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------
POSTGRES_DB=klinika
POSTGRES_USER=klinika
# REQUIRED — ≥32 chars of random hex.
POSTGRES_PASSWORD=

# ------------------------------------------------------------------
# Auth (Better-Auth)
# ------------------------------------------------------------------
# REQUIRED — ≥32 chars of high-entropy random material. Rotating it
# invalidates every active session.
AUTH_SECRET=
AUTH_TRUSTED_DEVICE_TTL_DAYS=30

# ------------------------------------------------------------------
# Tenancy — production suffix mode (matches klinika.health). The api
# + web middlewares treat `<slug>.klinika.health` as the tenant host
# and `klinika.health` as the platform apex. No prefix variables — the
# laptop is the canonical klinika.health install in 18b.3.
# ------------------------------------------------------------------
CLINIC_HOST_SUFFIX=.klinika.health

# Comma-separated list of additional CORS origins. The api also
# auto-accepts the apex + `<slug>.klinika.health` via a runtime regex.
CORS_ORIGIN=https://klinika.health

# ------------------------------------------------------------------
# Email
# ------------------------------------------------------------------
# Selection order: SMTP → Resend → capturing (stdout). On the laptop
# we run Resend until per-clinic SMTP is configured via Cilësimet.
EMAIL_FROM=no-reply@klinika.health
EMAIL_FROM_NAME=Klinika
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
RESEND_API_KEY=

# ------------------------------------------------------------------
# Seed (used only when running `seed:donetamed` on the laptop after
# the first deploy — not consumed by the api at runtime)
# ------------------------------------------------------------------
# Each value must be at least 12 characters; the seed aborts
# otherwise. Generate with `openssl rand -hex 16`. Record the
# generated values in a password manager — they are NOT printed to
# logs and the seed never re-emits them.
SEED_PLATFORM_ADMIN_PASSWORD=
SEED_DOCTOR_PASSWORD=
SEED_RECEPTIONIST_PASSWORD=
SEED_CLINIC_ADMIN_PASSWORD=

# ------------------------------------------------------------------
# Image tag — the donetamed compose file resolves
# `ghcr.io/ihox/klinika-{api,web}:${IMAGE_TAG}`. Defaults to `staging`
# during 18b bring-up; flip to `donetamed` once 18b.4 builds dedicated
# on-prem images.
# ------------------------------------------------------------------
IMAGE_TAG=staging

# ------------------------------------------------------------------
# Misc
# ------------------------------------------------------------------
JOBS_DISABLED=0
