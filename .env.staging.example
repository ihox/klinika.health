# Klinika — staging environment template
# Copy this file to .env.staging on the VM ONLY. Never commit a
# real .env.staging — it carries credentials and is gitignored.
#
# Generate the secret values once on the VM:
#     openssl rand -hex 32   # AUTH_SECRET
#     openssl rand -hex 24   # POSTGRES_PASSWORD
#     openssl rand -hex 16   # each SEED_*_PASSWORD
#
# The docker compose command in the deploy workflow loads this file
# via `--env-file .env.staging`. See infra/STAGING.md for the full
# bootstrap procedure.

# ------------------------------------------------------------------
# Runtime
# ------------------------------------------------------------------
NODE_ENV=production
TZ=Europe/Belgrade
APP_VERSION=staging
LOG_LEVEL=info

# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------
POSTGRES_DB=klinika
POSTGRES_USER=klinika
# REQUIRED — ≥32 chars of random hex. The api service composes
# DATABASE_URL from these three values internally; no need to set
# DATABASE_URL separately here.
POSTGRES_PASSWORD=

# ------------------------------------------------------------------
# Auth (Better-Auth)
# ------------------------------------------------------------------
# REQUIRED — ≥32 chars of high-entropy random material. Used to
# sign session cookies and trusted-device tokens; rotating it
# invalidates every active session.
AUTH_SECRET=
AUTH_TRUSTED_DEVICE_TTL_DAYS=30

# ------------------------------------------------------------------
# Tenancy
# ------------------------------------------------------------------
# Hostname suffix the api + web middlewares strip to recover the
# tenant subdomain. For staging this is the ihox.net delegation;
# production uses klinika.health.
CLINIC_HOST_SUFFIX=klinika.health.ihox.net

# Comma-separated list of additional CORS origins. The api also
# auto-accepts `*.${CLINIC_HOST_SUFFIX}` via a runtime regex, so
# only the apex needs to be listed here.
CORS_ORIGIN=https://klinika.health.ihox.net

# ------------------------------------------------------------------
# Email
# ------------------------------------------------------------------
# Selection order at startup:
#   1. SMTP_HOST + SMTP_USERNAME + SMTP_PASSWORD → SMTP sender
#   2. RESEND_API_KEY                            → Resend HTTP API
#   3. neither                                   → CapturingEmailSender
#      (writes the email body to api stdout — staging default)
EMAIL_FROM=no-reply@klinika.health.ihox.net
EMAIL_FROM_NAME=Klinika (staging)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
RESEND_API_KEY=

# ------------------------------------------------------------------
# Seed (used only when running `pnpm seed:staging` on the VM after
# the first deploy — not consumed by the api at runtime)
# ------------------------------------------------------------------
# Each value must be at least 12 characters; the seed aborts
# otherwise. Generate with `openssl rand -hex 16`. Document the
# generated values on a password manager — they are NOT printed
# to logs.
SEED_PLATFORM_ADMIN_PASSWORD=
SEED_DOCTOR_PASSWORD=
SEED_RECEPTIONIST_PASSWORD=
SEED_CLINIC_ADMIN_PASSWORD=

# ------------------------------------------------------------------
# Misc
# ------------------------------------------------------------------
# Background jobs (pg-boss). Leave 0 to enable; set 1 in CI runs.
JOBS_DISABLED=0
