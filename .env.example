# Klinika — environment template
# Copy to .env and fill in. Never commit a real .env file.

# Runtime
NODE_ENV=development
TZ=Europe/Belgrade

# Database
POSTGRES_DB=klinika
POSTGRES_USER=klinika
POSTGRES_PASSWORD=klinika
DATABASE_URL=postgresql://klinika:klinika@postgres:5432/klinika?schema=public

# API
API_PORT=3001
API_HOST=0.0.0.0
# Allowed origins for CORS (comma-separated). Wildcards via Caddy in prod.
CORS_ORIGIN=http://localhost:3000

# Web
WEB_PORT=3000
# Server-side URL the Next.js dev server proxies /api/* and /health/* to.
# Use the API container hostname inside Docker, localhost on bare metal.
API_INTERNAL_URL=http://api:3001

# Orthanc (DICOM)
ORTHANC_HTTP_PORT=8042
ORTHANC_DICOM_PORT=4242
ORTHANC_USERNAME=klinika
ORTHANC_PASSWORD=klinika
# Shared secret sent by Orthanc's on-stored.lua webhook in
# X-Klinika-Orthanc-Secret. Klinika's bridge rejects any event missing
# or mismatching this value. Rotate quarterly per the runbook.
ORTHANC_WEBHOOK_SECRET=klinika-webhook-dev

# Auth (Better-Auth)
# AUTH_SECRET is used by Better-Auth's primitives. Must be ≥ 32
# characters of high-entropy random material in production.
AUTH_SECRET=
AUTH_TRUSTED_DEVICE_TTL_DAYS=30
# Frontend base URL for password-reset links. In production set to
# `https://<tenant>.klinika.health`. Without this, the API tries to
# infer the URL from the request's clinic subdomain.
WEB_BASE_URL=

# Email transport. Selection order at startup:
#   1. SMTP_HOST + SMTP_USERNAME + SMTP_PASSWORD → SMTP sender
#   2. RESEND_API_KEY                            → Resend HTTP API
#   3. neither                                   → CapturingEmailSender
#      (prints the email body to API stdout; dev/test only)
EMAIL_FROM=no-reply@klinika.health
EMAIL_FROM_NAME=Klinika

# Option 1 — SMTP. Port defaults to 587 (STARTTLS); 465 uses implicit
# TLS; 25 works for plain-text test servers like Mailpit.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Option 2 — Resend HTTP API.
RESEND_API_KEY=

# Seed credentials — used only by `make db-seed`. Each value must be
# at least 12 characters; the seed script aborts otherwise. Rotate
# immediately after first login.
SEED_PLATFORM_ADMIN_PASSWORD=
SEED_DOCTOR_PASSWORD=
SEED_RECEPTIONIST_PASSWORD=

# Prisma slow-query threshold for the Pino logger (milliseconds).
# Queries slower than this log a warning with timing only (no PHI).
PRISMA_SLOW_QUERY_MS=500

# Logging
LOG_LEVEL=debug
APP_VERSION=0.0.0-dev

# Orthanc reachability (used by /health/deep + telemetry). Leave unset
# on cloud-only installs that don't run DICOM locally.
ORTHANC_URL=http://orthanc:8042

# Telemetry agent — runs on every install.
# Role: `agent` (default) or `platform`. Platform also runs the
# offline-sweep + retention jobs and receives heartbeats from agents.
TELEMETRY_ROLE=agent
KLINIKA_TENANT_ID=donetamed
TELEMETRY_HEARTBEAT_URL=https://klinika.health/api/telemetry/heartbeat
# Per-tenant bearer secret issued by the platform at onboarding.
TELEMETRY_SHARED_SECRET=
# Set TELEMETRY_DISABLED=1 in dev to suppress outbound heartbeats.
TELEMETRY_DISABLED=1

# Telemetry receiver (platform side only) — JSON map of tenant → secret.
# Example: {"donetamed":"abc...","demo":"def..."}
TELEMETRY_TENANT_SECRETS=

# Backup integration. The restic wrapper writes this env var after a
# successful run; the telemetry agent reads it for `lastBackupAt`.
BACKUP_LAST_SUCCESS_AT=

# Set to 1 to disable pg-boss entirely (useful in CI and unit-test runs).
JOBS_DISABLED=0
