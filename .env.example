# Klinika — environment template
# Copy to .env and fill in. Never commit a real .env file.

# Runtime
NODE_ENV=development
TZ=Europe/Belgrade

# Database
POSTGRES_DB=klinika
POSTGRES_USER=klinika
POSTGRES_PASSWORD=klinika
DATABASE_URL=postgresql://klinika:klinika@postgres:5432/klinika?schema=public

# API
API_PORT=3001
API_HOST=0.0.0.0
# Allowed origins for CORS (comma-separated). Wildcards via Caddy in prod.
CORS_ORIGIN=http://localhost:3000

# Web
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Orthanc (DICOM)
ORTHANC_HTTP_PORT=8042
ORTHANC_DICOM_PORT=4242
ORTHANC_USERNAME=klinika
ORTHANC_PASSWORD=klinika

# Auth (Better-Auth — populated in a later slice)
AUTH_SECRET=
AUTH_TRUSTED_DEVICE_TTL_DAYS=30

# Email (Resend — populated in a later slice)
RESEND_API_KEY=
EMAIL_FROM=no-reply@klinika.health

# Seed credentials — used only by `make db-seed`. Each value must be
# at least 12 characters; the seed script aborts otherwise. Rotate
# immediately after first login.
SEED_PLATFORM_ADMIN_PASSWORD=
SEED_DOCTOR_PASSWORD=
SEED_RECEPTIONIST_PASSWORD=

# Prisma slow-query threshold for the Pino logger (milliseconds).
# Queries slower than this log a warning with timing only (no PHI).
PRISMA_SLOW_QUERY_MS=500
