// Klinika — primary database schema.
//
// All clinical tables carry `clinic_id` and are protected by Postgres
// Row-Level Security policies (see migrations/manual/001_rls.sql and
// docs/decisions/005-multi-tenancy.md). The Prisma client never queries
// without `clinic_id` scoping; RLS is the second layer of defense.
//
// All `TIMESTAMPTZ` columns are stored in UTC and rendered in
// `Europe/Belgrade` at the UI layer (ADR-006). `created_at` defaults to
// `now()` at the database level. `updated_at` is maintained by both
// Prisma (`@updatedAt`) and a Postgres trigger (migrations/manual/002_triggers.sql)
// so raw-SQL updates also stay correct.
//
// Soft delete is the default (ADR-008): the Prisma middleware adds
// `WHERE deleted_at IS NULL` to all reads. Records are never physically
// removed in v1.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

/// Lifecycle state of a tenant clinic. Suspended clinics keep their data
/// but reject all logins and API traffic until reactivated by a platform
/// admin.
enum ClinicStatus {
  active
  suspended

  @@map("clinic_status")
}

/// Application roles within a clinic. Platform admins live in a separate
/// table and are not part of any clinic. Per CLAUDE.md §1.2, the
/// `receptionist` role sees only patient name and date of birth — all
/// other fields are hidden at UI, API, and RLS layers.
enum UserRole {
  doctor
  receptionist
  clinic_admin

  @@map("user_role")
}

/// Lifecycle states of a scheduled appointment.
enum AppointmentStatus {
  scheduled
  completed
  no_show
  cancelled

  @@map("appointment_status")
}

// ---------------------------------------------------------------------------
// Tenancy
// ---------------------------------------------------------------------------

/// A clinic is one tenant. Subdomain (`donetamed.klinika.health`) is the
/// public-facing identifier and is resolved on every request by
/// `ClinicResolutionMiddleware` (see ADR-005). All clinical tables FK to
/// `clinic_id`.
///
/// `hours_config` and `payment_codes` are clinic-specific JSON so a new
/// tenant can be onboarded without schema changes.
/// `smtp_config` is optional — clinics that don't override SMTP fall
/// back to the platform-wide Resend account.
model Clinic {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subdomain    String       @unique
  name         String
  shortName    String       @map("short_name")
  address      String
  city         String
  phones       String[]
  email        String
  hoursConfig  Json         @map("hours_config")
  paymentCodes Json         @map("payment_codes")
  logoUrl      String       @map("logo_url")
  signatureUrl String       @map("signature_url")
  smtpConfig   Json?        @map("smtp_config")
  status       ClinicStatus @default(active)
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?    @map("deleted_at") @db.Timestamptz(6)

  users             User[]
  patients          Patient[]
  visits            Visit[]
  appointments      Appointment[]
  vertetime         Vertetim[]
  dicomStudies      DicomStudy[]
  prescriptionLines PrescriptionLine[]

  @@map("clinics")
}

/// A user account belonging to one clinic. Email is globally unique so a
/// single person cannot belong to two clinics — they would need separate
/// emails (intentional, per ADR-004).
///
/// Doctors carry `signature_url` for printed prescriptions and
/// `vërtetime` documents. Receptionists and clinic admins typically do
/// not, though the field is available for all roles.
model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clinicId     String    @map("clinic_id") @db.Uuid
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         UserRole
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  title        String?
  credential   String?
  signatureUrl String?   @map("signature_url")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  clinic              Clinic                   @relation(fields: [clinicId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  visitsCreated       Visit[]                  @relation("VisitCreatedBy")
  visitsUpdated       Visit[]                  @relation("VisitUpdatedBy")
  appointmentsCreated Appointment[]            @relation("AppointmentCreatedBy")
  vertetimeIssued     Vertetim[]               @relation("VertetimIssuedBy")
  dicomLinksCreated   VisitDicomLink[]         @relation("DicomLinkLinkedBy")
  prescriptionLines   PrescriptionLine[]
  authSessions        AuthSession[]
  trustedDevices      AuthTrustedDevice[]
  mfaCodes            AuthMfaCode[]
  passwordResets      AuthPasswordResetToken[]

  @@index([clinicId])
  @@map("users")
}

/// Platform admins (founder, support, on-call ops) — not part of any
/// clinic. They use a separate Postgres role (`platform_admin_role`)
/// with `BYPASSRLS` for cross-tenant queries. See ADR-005.
///
/// No `deleted_at` — admin accounts are toggled active/inactive instead;
/// permanent removal is via SQL only.
model PlatformAdmin {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String    @unique
  passwordHash String    @map("password_hash")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  adminSessions        AuthAdminSession[]
  adminMfaCodes        AuthAdminMfaCode[]
  platformAuditEntries PlatformAuditLog[]

  @@map("platform_admins")
}

/// Platform-admin session. Parallel to {@link AuthSession} but bound to
/// {@link PlatformAdmin}, not a clinic user. No `clinic_id` — platform
/// admins are cross-tenant by design (ADR-005). The cookie name differs
/// (`klinika_admin_session`) so a leaked tenant session can never be
/// mistaken for an admin session on the API.
///
/// MFA is enforced on every admin login — no trusted-device shortcut —
/// so this slice does not introduce an `auth_admin_trusted_devices`
/// counterpart.
model AuthAdminSession {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  platformAdminId String    @map("platform_admin_id") @db.Uuid
  tokenHash       String    @unique @map("token_hash")
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz(6)
  ipAddress       String    @map("ip_address") @db.Inet
  userAgent       String    @map("user_agent")
  deviceLabel     String    @map("device_label")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastUsedAt      DateTime  @default(now()) @map("last_used_at") @db.Timestamptz(6)
  revokedAt       DateTime? @map("revoked_at") @db.Timestamptz(6)
  revokedReason   String?   @map("revoked_reason")

  platformAdmin PlatformAdmin @relation(fields: [platformAdminId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([platformAdminId])
  @@index([expiresAt])
  @@map("auth_admin_sessions")
}

/// Pending email MFA code for a platform-admin login. 6 digits, 15-min
/// TTL, 3-attempt limit. Same shape as {@link AuthMfaCode} but without
/// `clinic_id` and without the `remember_device` / `extended_ttl`
/// columns (admin sessions are always short-lived, MFA every login).
model AuthAdminMfaCode {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  platformAdminId  String    @map("platform_admin_id") @db.Uuid
  pendingSessionId String    @unique @map("pending_session_id")
  codeHash         String    @map("code_hash")
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  attempts         Int       @default(0)
  consumedAt       DateTime? @map("consumed_at") @db.Timestamptz(6)
  ipAddress        String    @map("ip_address") @db.Inet
  userAgent        String    @map("user_agent")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  platformAdmin PlatformAdmin @relation(fields: [platformAdminId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([platformAdminId])
  @@index([expiresAt])
  @@map("auth_admin_mfa_codes")
}

/// Append-only log of platform-admin actions (tenant creation, suspend,
/// activate, new admin created, etc). Separate from {@link AuditLog}
/// because the per-clinic audit log requires both `clinic_id` and a
/// clinic user — platform admins are neither. Rows are visible to all
/// platform admins; no RLS. The `targetClinicId` is set when the action
/// touches a specific tenant (suspend, activate, create), and null for
/// platform-wide actions (creating another platform admin).
model PlatformAuditLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  platformAdminId String   @map("platform_admin_id") @db.Uuid
  action          String
  targetClinicId  String?  @map("target_clinic_id") @db.Uuid
  resourceType    String   @map("resource_type")
  resourceId      String   @map("resource_id")
  metadata        Json?
  ipAddress       String   @map("ip_address") @db.Inet
  userAgent       String   @map("user_agent")
  sessionId       String   @map("session_id")
  timestamp       DateTime @default(now()) @db.Timestamptz(6)

  platformAdmin PlatformAdmin @relation(fields: [platformAdminId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([platformAdminId, timestamp])
  @@index([targetClinicId, timestamp])
  @@index([action, timestamp])
  @@map("platform_audit_log")
}

// ---------------------------------------------------------------------------
// Clinical core
// ---------------------------------------------------------------------------

/// A patient (pediatric — DonetaMED's first cohort is ages 0-18).
/// `legacy_id` is the source `ID` field from the Access migration
/// (ADR-010) and is unique within a clinic; new patients created after
/// migration have `legacy_id = NULL`. Patient names migrate with
/// asterisks stripped per ADR-010.
///
/// `alergji_tjera` ("other allergies" in Albanian) is the free-text
/// allergy field from the Access source. Birth measurements migrate
/// from `PL`/`Pesha lindjes` and friends; `0` in source maps to NULL.
model Patient {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clinicId                 String    @map("clinic_id") @db.Uuid
  legacyId                 Int?      @map("legacy_id")
  firstName                String    @map("first_name")
  lastName                 String    @map("last_name")
  dateOfBirth              DateTime  @map("date_of_birth") @db.Date
  placeOfBirth             String?   @map("place_of_birth")
  birthWeightG             Int?      @map("birth_weight_g")
  birthHeadCircumferenceCm Decimal?  @map("birth_head_circumference_cm") @db.Decimal(5, 2)
  birthLengthCm            Decimal?  @map("birth_length_cm") @db.Decimal(5, 2)
  alergjiTjera             String?   @map("alergji_tjera") @db.Text
  phone                    String?
  createdAt                DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                DateTime? @map("deleted_at") @db.Timestamptz(6)

  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  visits       Visit[]
  appointments Appointment[]
  vertetime    Vertetim[]

  @@unique([clinicId, legacyId], name: "patient_clinic_legacy_unique")
  @@index([clinicId])
  @@map("patients")
}

/// A clinical visit. The doctor's daily working surface. Most fields are
/// optional because doctors fill in only what is relevant. `complaint`,
/// `examinations`, `prescription`, `lab_results`, `followup_notes`, and
/// `other_notes` are the main free-text fields and are redacted from all
/// logs per CLAUDE.md §1.3.
///
/// `payment_code` is a single character (E/A/B/C/D) describing the
/// patient's payment status — preserved from the Access source.
/// `legacy_diagnosis` is the raw text diagnosis from the Access source;
/// new visits use the structured `visit_diagnoses` join table against
/// `icd10_codes`.
model Visit {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clinicId            String    @map("clinic_id") @db.Uuid
  patientId           String    @map("patient_id") @db.Uuid
  legacyId            Int?      @map("legacy_id")
  visitDate           DateTime  @map("visit_date") @db.Date
  complaint           String?   @db.Text
  feedingNotes        String?   @map("feeding_notes") @db.Text
  feedingBreast       Boolean   @default(false) @map("feeding_breast")
  feedingFormula      Boolean   @default(false) @map("feeding_formula")
  feedingSolid        Boolean   @default(false) @map("feeding_solid")
  weightG             Int?      @map("weight_g")
  heightCm            Decimal?  @map("height_cm") @db.Decimal(5, 2)
  headCircumferenceCm Decimal?  @map("head_circumference_cm") @db.Decimal(5, 2)
  temperatureC        Decimal?  @map("temperature_c") @db.Decimal(4, 2)
  paymentCode         String?   @map("payment_code") @db.Char(1)
  examinations        String?   @db.Text
  ultrasoundNotes     String?   @map("ultrasound_notes") @db.Text
  legacyDiagnosis     String?   @map("legacy_diagnosis") @db.Text
  prescription        String?   @db.Text
  labResults          String?   @map("lab_results") @db.Text
  followupNotes       String?   @map("followup_notes") @db.Text
  otherNotes          String?   @map("other_notes") @db.Text
  createdBy           String    @map("created_by") @db.Uuid
  updatedBy           String    @map("updated_by") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz(6)

  clinic        Clinic           @relation(fields: [clinicId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient       Patient          @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdByUser User             @relation("VisitCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedByUser User             @relation("VisitUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  diagnoses     VisitDiagnosis[]
  vertetime     Vertetim[]
  dicomLinks    VisitDicomLink[]

  @@unique([clinicId, legacyId], name: "visit_clinic_legacy_unique")
  @@index([clinicId])
  @@index([patientId])
  @@map("visits")
}

/// Structured diagnoses on a visit. Replaces the free-text diagnosis
/// approach of the Access source. `order_index` preserves the doctor's
/// chosen ordering (primary diagnosis first by convention).
model VisitDiagnosis {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  visitId    String @map("visit_id") @db.Uuid
  icd10Code  String @map("icd10_code")
  orderIndex Int    @map("order_index")

  visit Visit     @relation(fields: [visitId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  code  Icd10Code @relation(fields: [icd10Code], references: [code], onDelete: NoAction, onUpdate: NoAction)

  @@index([visitId])
  @@index([icd10Code])
  @@map("visit_diagnoses")
}

/// WHO ICD-10 catalogue. Pre-populated from
/// `apps/api/prisma/fixtures/icd10.csv` (Latin descriptions only — UI
/// shows codes and Latin per CLAUDE.md §1.5). `common = true` flags
/// frequently-used pediatric codes that surface first in the ICD-10
/// multi-select.
model Icd10Code {
  code             String  @id
  latinDescription String  @map("latin_description") @db.Text
  chapter          String
  common           Boolean @default(false)

  diagnoses VisitDiagnosis[]

  @@index([common])
  @@map("icd10_codes")
}

/// Per-doctor index of prescription text snippets, used to power
/// autocomplete in the prescription field. `use_count` and timestamps
/// drive ranking (most-used + most-recent first). Owned by both the
/// user (autocomplete is personal) and the clinic (defense-in-depth for
/// RLS).
model PrescriptionLine {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  clinicId    String   @map("clinic_id") @db.Uuid
  lineText    String   @map("line_text") @db.Text
  useCount    Int      @default(1) @map("use_count")
  lastUsedAt  DateTime @map("last_used_at") @db.Timestamptz(6)
  firstUsedAt DateTime @map("first_used_at") @db.Timestamptz(6)

  user   User   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([clinicId])
  @@map("prescription_lines")
}

// ---------------------------------------------------------------------------
// Scheduling
// ---------------------------------------------------------------------------

/// A scheduled appointment. `scheduled_for` is `TIMESTAMPTZ` because the
/// time matters; the UI renders in Europe/Belgrade.
model Appointment {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clinicId        String            @map("clinic_id") @db.Uuid
  patientId       String            @map("patient_id") @db.Uuid
  scheduledFor    DateTime          @map("scheduled_for") @db.Timestamptz(6)
  durationMinutes Int               @map("duration_minutes")
  status          AppointmentStatus @default(scheduled)
  createdBy       String            @map("created_by") @db.Uuid
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?         @map("deleted_at") @db.Timestamptz(6)

  clinic        Clinic  @relation(fields: [clinicId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient       Patient @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdByUser User    @relation("AppointmentCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([clinicId])
  @@index([patientId])
  @@index([scheduledFor])
  @@map("appointments")
}

// ---------------------------------------------------------------------------
// Documents
// ---------------------------------------------------------------------------

/// Vërtetim — Albanian medical certificate / sick note. Once issued, a
/// vërtetim is immutable (no `updated_at`, no soft delete) because it's
/// a legal record. `diagnosis_snapshot` captures the diagnosis text at
/// the moment of issue so subsequent edits to the visit don't change
/// the printed document (per CLAUDE.md §1.8).
model Vertetim {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clinicId          String   @map("clinic_id") @db.Uuid
  patientId         String   @map("patient_id") @db.Uuid
  visitId           String   @map("visit_id") @db.Uuid
  issuedBy          String   @map("issued_by") @db.Uuid
  issuedAt          DateTime @map("issued_at") @db.Timestamptz(6)
  absenceFrom       DateTime @map("absence_from") @db.Date
  absenceTo         DateTime @map("absence_to") @db.Date
  diagnosisSnapshot String   @map("diagnosis_snapshot") @db.Text
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  clinic       Clinic  @relation(fields: [clinicId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patient      Patient @relation(fields: [patientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  visit        Visit   @relation(fields: [visitId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  issuedByUser User    @relation("VertetimIssuedBy", fields: [issuedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([clinicId])
  @@index([patientId])
  @@index([visitId])
  @@map("vertetime")
}

// ---------------------------------------------------------------------------
// DICOM
// ---------------------------------------------------------------------------

/// A DICOM study received by Orthanc. `orthanc_study_id` is Orthanc's
/// internal study identifier (used to fetch image data via the proxy).
/// The image bytes live in Orthanc, not in Postgres; this table is the
/// index Klinika uses to authorize access and link to visits.
model DicomStudy {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clinicId       String   @map("clinic_id") @db.Uuid
  orthancStudyId String   @map("orthanc_study_id")
  receivedAt     DateTime @map("received_at") @db.Timestamptz(6)
  imageCount     Int      @map("image_count")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  clinic Clinic           @relation(fields: [clinicId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  links  VisitDicomLink[]

  @@unique([clinicId, orthancStudyId], name: "dicom_clinic_orthanc_unique")
  @@index([clinicId])
  @@map("dicom_studies")
}

/// Join table: a visit can link to multiple DICOM studies, a study can
/// link to multiple visits (e.g. follow-up reads). `linked_by` records
/// which user attached the study.
model VisitDicomLink {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  visitId      String   @map("visit_id") @db.Uuid
  dicomStudyId String   @map("dicom_study_id") @db.Uuid
  linkedAt     DateTime @default(now()) @map("linked_at") @db.Timestamptz(6)
  linkedBy     String   @map("linked_by") @db.Uuid

  visit        Visit      @relation(fields: [visitId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dicomStudy   DicomStudy @relation(fields: [dicomStudyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  linkedByUser User       @relation("DicomLinkLinkedBy", fields: [linkedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([visitId, dicomStudyId], name: "visit_dicom_unique")
  @@index([visitId])
  @@index([dicomStudyId])
  @@map("visit_dicom_links")
}

// ---------------------------------------------------------------------------
// Audit
// ---------------------------------------------------------------------------

/// Append-mostly audit log. Every mutation on clinical or sensitive data
/// writes a row here (see CLAUDE.md §5.3). Successive saves within 60
/// seconds by the same user on the same resource coalesce by updating
/// the most-recent row's `changes` array — this is the only mutation
/// path. Reads of sensitive resources (chart open, document print)
/// write rows with `changes = NULL`.
///
/// PHI must never appear in this table outside of the `changes` JSONB
/// field, where it's expected (diff content) and access-controlled.
/// `ip_address` is `INET` to allow CIDR queries during incident
/// investigation.
model AuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clinicId     String   @map("clinic_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  action       String
  resourceType String   @map("resource_type")
  resourceId   String   @map("resource_id") @db.Uuid
  changes      Json?
  ipAddress    String   @map("ip_address") @db.Inet
  userAgent    String   @map("user_agent")
  sessionId    String   @map("session_id")
  timestamp    DateTime @default(now()) @db.Timestamptz(6)

  @@index([clinicId, timestamp])
  @@index([resourceType, resourceId])
  @@map("audit_log")
}

// ---------------------------------------------------------------------------
// Telemetry (platform-side)
// ---------------------------------------------------------------------------

/// Severity of a telemetry-derived alert.
enum AlertSeverity {
  critical
  warning

  @@map("alert_severity")
}

/// Heartbeat received from a tenant install (cloud or on-premise).
///
/// Payload is metadata only — CPU/RAM/disk percentages, queue depths,
/// reachability flags. **Never PHI.** A `tenantId` is the subdomain
/// (`donetamed`); cloud-hosted installs and the platform tenant emit
/// heartbeats too. Rows older than 90 days are pruned by a scheduled
/// job (see `apps/api/src/modules/telemetry/`).
model TelemetryHeartbeat {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id")
  version        String
  receivedAt     DateTime  @default(now()) @map("received_at") @db.Timestamptz(6)
  emittedAt      DateTime  @map("emitted_at") @db.Timestamptz(6)
  appHealthy     Boolean   @map("app_healthy")
  dbHealthy      Boolean   @map("db_healthy")
  orthancHealthy Boolean   @map("orthanc_healthy")
  cpuPercent     Decimal   @map("cpu_percent") @db.Decimal(5, 2)
  ramPercent     Decimal   @map("ram_percent") @db.Decimal(5, 2)
  diskPercent    Decimal   @map("disk_percent") @db.Decimal(5, 2)
  lastBackupAt   DateTime? @map("last_backup_at") @db.Timestamptz(6)
  activeSessions Int       @map("active_sessions")
  queueDepth     Int       @map("queue_depth")
  errorRate5xx   Int       @map("error_rate_5xx")
  payload        Json

  @@index([tenantId, receivedAt])
  @@index([receivedAt])
  @@map("telemetry_heartbeats")
}

/// Critical or warning alerts derived from heartbeat anomalies.
/// Critical alerts trigger immediate notification; warnings are batched
/// into the daily 9am digest. `dedupeKey` lets the alert engine coalesce
/// repeated identical conditions (e.g. one disk-full alert per tenant
/// per day instead of one per heartbeat).
model TelemetryAlert {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String        @map("tenant_id")
  severity   AlertSeverity
  kind       String
  message    String        @db.Text
  dedupeKey  String        @map("dedupe_key")
  notifiedAt DateTime?     @map("notified_at") @db.Timestamptz(6)
  digestedAt DateTime?     @map("digested_at") @db.Timestamptz(6)
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([tenantId, createdAt])
  @@index([dedupeKey])
  @@index([severity, notifiedAt])
  @@map("telemetry_alerts")
}

// ---------------------------------------------------------------------------
// Authentication (Better-Auth-style; see ADR-004)
// ---------------------------------------------------------------------------
//
// The cookie/token sent to the browser is a long random string (256 bits,
// nanoid). The DB stores SHA-256 of that token so a leaked dump can't be
// used to assume sessions. Same pattern for MFA codes, password reset
// tokens, and trusted-device tokens.
//
// `clinicId` is denormalised onto auth rows so the rate limiter and
// audit log can scope without joining `users` (which RLS protects). Auth
// tables stay outside the per-clinic RLS policy because login itself
// happens before the clinic context is established; cross-tenant access
// is prevented at the application layer by joining `users.clinicId` to
// the subdomain-derived clinic_id on every authenticated request.

/// Server-side session record. The cookie holds the raw token; this
/// table holds its hash plus the metadata for the user-visible "active
/// sessions" list and for revocation. `extendedTtl` reflects the
/// "Më mbaj të kyçur" checkbox — when true, the session lasts 30 days
/// instead of the default 8 hours.
model AuthSession {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  clinicId      String    @map("clinic_id") @db.Uuid
  tokenHash     String    @unique @map("token_hash")
  expiresAt     DateTime  @map("expires_at") @db.Timestamptz(6)
  extendedTtl   Boolean   @default(false) @map("extended_ttl")
  ipAddress     String    @map("ip_address") @db.Inet
  userAgent     String    @map("user_agent")
  deviceLabel   String    @map("device_label")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastUsedAt    DateTime  @default(now()) @map("last_used_at") @db.Timestamptz(6)
  revokedAt     DateTime? @map("revoked_at") @db.Timestamptz(6)
  revokedReason String?   @map("revoked_reason")

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

/// Trusted device — a long-lived cookie that bypasses email MFA on
/// subsequent logins from the same browser for 30 days. The cookie is
/// scoped per user (the cookie value identifies the user; the user types
/// password every time). On every login, we look up by `(userId,
/// tokenHash)` and only skip MFA if the row is unrevoked and unexpired.
model AuthTrustedDevice {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  clinicId   String    @map("clinic_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  label      String
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastSeenAt DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  ipAddress  String    @map("ip_address") @db.Inet
  userAgent  String    @map("user_agent")
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_trusted_devices")
}

/// Email-delivered MFA code. 6-digit code, hashed at rest, 15-minute
/// TTL, max 3 verification attempts. `pendingSessionId` is an opaque
/// handle returned to the browser after a successful password check so
/// the verify page can submit the code without re-sending the password.
model AuthMfaCode {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  clinicId         String    @map("clinic_id") @db.Uuid
  pendingSessionId String    @unique @map("pending_session_id")
  codeHash         String    @map("code_hash")
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  attempts         Int       @default(0)
  consumedAt       DateTime? @map("consumed_at") @db.Timestamptz(6)
  rememberDevice   Boolean   @default(true) @map("remember_device")
  extendedTtl      Boolean   @default(false) @map("extended_ttl")
  ipAddress        String    @map("ip_address") @db.Inet
  userAgent        String    @map("user_agent")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_mfa_codes")
}

/// Append-only record of every login attempt, success or failure.
/// Drives the per-email rate limit and supports incident forensics
/// without storing the password attempt itself.
model AuthLoginAttempt {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  emailLower String   @map("email_lower")
  ipAddress  String   @map("ip_address") @db.Inet
  userAgent  String   @map("user_agent")
  success    Boolean
  reason     String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([emailLower, createdAt])
  @@index([ipAddress, createdAt])
  @@map("auth_login_attempts")
}

/// Single-use password reset token. 1-hour TTL. Hashed at rest. The
/// token is delivered in the email link as `?t=<raw>`; the user clicks
/// it, then types the new password.
model AuthPasswordResetToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  ipAddress  String    @map("ip_address") @db.Inet
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_password_reset_tokens")
}

// ---------------------------------------------------------------------------
// Rate limiting (CLAUDE.md §9)
// ---------------------------------------------------------------------------

/// Sliding-window rate limit counter. `scope` is the bucket name
/// (`auth.login.ip`, `auth.login.email`, `auth.mfa.send`, `api.user`,
/// etc.), `key` is the bucket value (IP, email lowercase, user id),
/// `windowEndsAt` is when this row's count resets. The rate-limit
/// middleware upserts on `(scope, key)` and rejects when `count` >
/// the configured limit for that scope.
model RateLimit {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scope        String
  key          String
  count        Int      @default(0)
  windowEndsAt DateTime @map("window_ends_at") @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([scope, key], name: "rate_limit_scope_key_unique")
  @@index([windowEndsAt])
  @@map("rate_limits")
}
